{
  "name": "postgrip",
  "productName": "PostGrip",
  "version": "0.3.0",
  "description": "Desktop PostgreSQL database client",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build": "bun run build:main && bun run build:preload && bun run build:renderer",
    "dev": "vite --config vite.renderer.config.ts & sleep 2 && VITE_DEV_SERVER_URL=http://localhost:5173 bun run build:main && bun run build:preload && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start": "bun run build && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:live": "vitest run --config vitest.live.config.ts",
    "test:e2e": "bun run build && playwright test",
    "test:e2e:headed": "bun run build && playwright test --headed",
    "test:all": "vitest run && vitest run --config vitest.live.config.ts && bun run build && playwright test",
    "dist": "bun run build && electron-builder --publish never",
    "dist:mac": "bun run build && electron-builder --mac --publish never",
    "dist:win": "bun run build && electron-builder --win --publish never",
    "dist:linux": "bun run build && electron-builder --linux --publish never"
  },
  "build": {
    "appId": "com.postgrip.app",
    "productName": "PostGrip",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "docs/**/*",
      "node_modules/**/*",
      "!node_modules/ssh2/lib/protocol/crypto/build",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-mac.${ext}"
    },
    "win": {
      "icon": "build/icon_256x256.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win.${ext}"
    },
    "linux": {
      "icon": "build/icon_256x256.png",
      "category": "Development",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-linux.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "4.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.5",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.3.1",
    "electron": "41.1.0",
    "electron-builder": "^26.8.1",
    "electron-playwright-helpers": "^2.1.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "4.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-sql": "^6.8.0",
    "@codemirror/language": "^6.10.8",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.5",
    "parquetjs-lite": "^0.8.7",
    "pg": "^8.13.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ssh2": "^1.17.0"
  }
}
